{
    "id": "example_1",
    "title": "Point Moving on Shapes",
    "tags": [
        "circle",
        "dot",
        "move_along_path"
    ],
    "elements": [
        {
            "id": "circle_1",
            "type": "circle",
            "props": {
                "radius": 1,
                "color": "BLUE",
                "fill_opacity": 0
            },
            "position": [
                0,
                0,
                0
            ],
            "z_index": 0
        },
        {
            "id": "dot_1",
            "type": "dot",
            "props": {
                "color": "WHITE"
            },
            "position": [
                0,
                0,
                0
            ],
            "z_index": 1
        },
        {
            "id": "line_1",
            "type": "line",
            "props": {
                "start": [
                    3,
                    0,
                    0
                ],
                "end": [
                    5,
                    0,
                    0
                ],
                "color": "WHITE"
            },
            "z_index": 0
        }
    ],
    "animations": [
        {
            "id": "anim_1",
            "type": "grow_from_center",
            "target": "circle_1",
            "start_time": 0,
            "duration": 1
        },
        {
            "id": "anim_2",
            "type": "transform",
            "target": "dot_1",
            "to": {
                "position": [
                    1,
                    0,
                    0
                ]
            },
            "start_time": 1,
            "duration": 1
        },
        {
            "id": "anim_3",
            "type": "move_along_path",
            "target": "dot_1",
            "path": "circle_1",
            "start_time": 2,
            "duration": 2,
            "rate_func": "linear"
        },
        {
            "id": "anim_4",
            "type": "rotating",
            "target": "dot_1",
            "about_point": [
                2,
                0,
                0
            ],
            "start_time": 4,
            "duration": 1.5
        }
    ],
    "duration": 5.5
}